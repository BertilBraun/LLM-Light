{"task_id":"count_positive","prompt":"def count_positive(values: list[int]) -> int:\n","checks":["count_positive([]) == 0","count_positive([-1, 0, 2, 3]) == 2","count_positive([1, 2, 3]) == 3","count_positive([-5, -1]) == 0"]}
{"task_id":"filter_by_prefix","prompt":"def filter_by_prefix(strings: list[str], prefix: str) -> list[str]:\n","checks":["filter_by_prefix(['ant', 'bee', 'apple'], 'a') == ['ant', 'apple']","filter_by_prefix([], 'x') == []","filter_by_prefix(['one'], 'z') == []","filter_by_prefix(['pre', 'prefix', 'xpre'], 'pre') == ['pre', 'prefix']"]}
{"task_id":"count_word_occurrences","prompt":"def count_word_occurrences(words: list[str]) -> dict[str, int]:\n","checks":["count_word_occurrences([]) == {}","count_word_occurrences(['a', 'b', 'a']) == {'a': 2, 'b': 1}","count_word_occurrences(['x']) == {'x': 1}","count_word_occurrences(['red', 'red', 'blue', 'red']) == {'red': 3, 'blue': 1}"]}
{"task_id":"first_divisible","prompt":"def first_divisible(values: list[int], divisor: int) -> int | None:\n","checks":["first_divisible([3, 4, 6], 2) == 4","first_divisible([5, 7], 3) is None","first_divisible([], 2) is None","first_divisible([9, 12, 15], 3) == 9"]}
{"task_id":"sum_even","prompt":"def sum_even(values: list[int]) -> int:\n","checks":["sum_even([]) == 0","sum_even([1, 2, 3, 4]) == 6","sum_even([1, 3, 5]) == 0","sum_even([-2, 2, 5]) == 0"]}
{"task_id":"deduplicate_preserving_order","prompt":"def deduplicate_preserving_order(items: list[int | str]) -> list[int | str]:\n","checks":["deduplicate_preserving_order([]) == []","deduplicate_preserving_order([1, 1, 2, 1, 3]) == [1, 2, 3]","deduplicate_preserving_order(['a', 'b', 'a']) == ['a', 'b']","deduplicate_preserving_order([0, 0, 0]) == [0]"]}
{"task_id":"group_by_first_letter","prompt":"def group_by_first_letter(words: list[str]) -> dict[str, list[str]]:\n","checks":["group_by_first_letter([]) == {}","group_by_first_letter(['ant', 'ape', 'bee']) == {'a': ['ant', 'ape'], 'b': ['bee']}","group_by_first_letter(['x']) == {'x': ['x']}","group_by_first_letter(['car', 'cat', 'dog']) == {'c': ['car', 'cat'], 'd': ['dog']}"]}
{"task_id":"clamp_values","prompt":"def clamp_values(values: list[int], minimum: int, maximum: int) -> list[int]:\n","checks":["clamp_values([], 0, 10) == []","clamp_values([-1, 5, 12], 0, 10) == [0, 5, 10]","clamp_values([1, 2], 0, 10) == [1, 2]","clamp_values([-5, -1, 3], -2, 2) == [-2, -1, 2]"]}
